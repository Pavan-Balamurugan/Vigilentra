# Vigilentra Backend Configuration
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=sqlite:///./vigilentra.db

# JWT Authentication
JWT_SECRET=change-this-to-a-random-secret-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# VirusTotal API (free tier: 4 requests/minute, 500/day)
# Get your key at: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# Google Safe Browsing API (free tier: 10,000 requests/day)
# Get your key at: https://console.cloud.google.com/apis/library/safebrowsing.googleapis.com
SAFE_BROWSING_API_KEY=

# Rate limiting
RATE_LIMIT_PER_MINUTE=20

# CORS (comma-separated origins, or * for development)
CORS_ORIGINS=*
